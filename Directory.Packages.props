    <!-- 通信 -->
    <PackageVersion Include="Fleck" Version="1.2.0" />
    <PackageVersion Include="HslCommunication" Version="10.6.1" />
    <PackageVersion Include="MQTTnet" Version="4.3.7.1207" />

    <!-- 业务规则引擎 -->
    <PackageVersion Include="NLua" Version="1.7.3" />
    <PackageVersion Include="RulesEngine" Version="5.0.0" />
    <PackageVersion Include="Scriban" Version="7.1.0" />
    <PackageVersion Include="SqlKata" Version="2.4.0" />

    <!-- 测试 -->
    <PackageVersion Include="xunit" Version="2.9.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="coverlet.collector" Version="6.0.2" />

    <!-- 源码调试 -->
    <PackageVersion Include="Microsoft.SourceLink.GitHub" Version="8.0.0" />

    <!-- ProtocolGateway 专用依赖 -->
    <PackageVersion Include="BACnet" Version="2.0.4" />
    <PackageVersion Include="Microsoft.Data.SqlClient" Version="5.2.3" />
    <PackageVersion Include="OPCFoundation.NetStandard.Opc.Ua" Version="1.5.378.134" />
    <PackageVersion Include="Dapper" Version="2.1.35" />
    <PackageVersion Include="MySqlConnector" Version="2.3.0" />
    <PackageVersion Include="Npgsql" Version="8.0.0" />
    <PackageVersion Include="System.Threading.RateLimiting" Version="8.0.0" />
    <PackageVersion Include="Microsoft.Bcl.AsyncInterfaces" Version="10.0.2" />
    <PackageVersion Include="NSubstitute" Version="5.1.0" />
    <PackageVersion Include="NLog.Database" Version="5.3.4" />
    <PackageVersion Include="NLog.Targets.JsonFile" Version="2.0.6" />
    <PackageVersion Include="System.Management" Version="10.0.1" />
    <PackageVersion Include="System.Security.Cryptography.Pkcs" Version="8.0.0" />
    <PackageVersion Include="xunit.assert" Version="2.9.2" />
  </ItemGroup>
</Project>
