<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ZL.Scripting</AssemblyName>
    <RootNamespace>ZL.Scripting</RootNamespace>
    <Description>ZL IoT SDK — Lua 脚本引擎（基于 NLua），包含 ScriptContext、ScriptEngine 和脚本输出插件</Description>
    <PackageTags>ZL;IoT;Lua;Scripting;NLua;Industrial</PackageTags>
    <NoWarn>$(NoWarn);NU1603;NU1605</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NLua" />
  </ItemGroup>

  <!-- ProtocolGateway 引用：优先用本地项目，后续改为 NuGet -->
  <ItemGroup>
    <ProjectReference Include="../../../../ZL.PlcSimulator/src/ProtocolGateway/src/ProtocolGateway/ProtocolGateway.csproj" Condition="Exists('../../../../ZL.PlcSimulator/src/ProtocolGateway/src/ProtocolGateway/ProtocolGateway.csproj')" />
  </ItemGroup>
</Project>
