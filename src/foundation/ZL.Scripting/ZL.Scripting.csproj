<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ZL.Scripting</AssemblyName>
    <RootNamespace>ZL.Scripting</RootNamespace>
    <Description>ZL IoT SDK — Lua 脚本引擎（基于 NLua / Lua 5.1），支持超时中断和线程安全执行</Description>
    <PackageTags>ZL;IoT;Lua;Scripting;NLua</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NLua" />
  </ItemGroup>
</Project>
