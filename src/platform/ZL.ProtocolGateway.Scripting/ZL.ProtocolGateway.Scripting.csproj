<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    
    <LangVersion>12.0</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;NU1603;NU1605;NU1902;NU1903</NoWarn>
    <PackageId>ProtocolGateway.Scripting</PackageId>
    <Version>1.0.0</Version>
    <Authors>UseThink</Authors>
    <Company>有思智联</Company>
    <Description>ProtocolGateway Lua 脚本引擎 — 基于 NLua 的 Lua 5.1 脚本支持，可作为独立 DLL 被多个项目引用</Description>
    <PackageTags>protocol;gateway;lua;scripting;nlua;iot;industrial</PackageTags>
    <RepositoryUrl>https://github.com/qwdingyu/ZL.PlcSimulator</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ZL.ProtocolGateway.Tests" />
    <!-- Scripting 深度依赖 ProtocolGateway 内部类型（Message/TagWrite/Plugins），
         混淆后会丢失符号。必须用 ProjectReference 确保源码编译一致性。
         PrivateAssets=all 阻止 pack 时将 ProtocolGateway 声明为传递依赖。 -->
    <ProjectReference Include="..\ZL.ProtocolGateway\ZL.ProtocolGateway.csproj"
                      PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NLua"  />
  </ItemGroup>

</Project>
