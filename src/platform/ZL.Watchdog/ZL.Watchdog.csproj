<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>netstandard2.0</TargetFrameworks>
        <AssemblyName>ZL.Watchdog</AssemblyName>
        <RootNamespace>ZL.Watchdog</RootNamespace>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <LangVersion>latest</LangVersion>
        <Nullable>disable</Nullable>
        <ImplicitUsings>disable</ImplicitUsings>
        <Description>Generic watchdog service for monitoring and auto-restarting unhealthy components. Protocol-agnostic, reusable across any .NET project.</Description>
        <PackageTags>watchdog;health-check;auto-restart;monitoring;iot</PackageTags>
    </PropertyGroup>
</Project>
