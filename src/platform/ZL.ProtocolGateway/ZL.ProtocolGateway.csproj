<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;NU1603;NU1605;NU1902;NU1903;CS8632;CS0414;NETSDK1206</NoWarn>
    <PackageId>ProtocolGateway</PackageId>
    <Version>1.0.0</Version>
    <Authors>UseThink</Authors>
    <Company>有思智联</Company>
    <Description>轻量级协议转发中间类库，支持 Serial/MQTT/TCP/HTTP/BACnet/OPC UA 等工业协议互转</Description>
    <PackageTags>protocol;gateway;iot;mqtt;serial;tcp;http;converter;industrial;bacnet;opcua</PackageTags>
    <RepositoryUrl>https://github.com/qwdingyu/ZL.PlcSimulator</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ZL.ProtocolGateway.Tests" />
    <InternalsVisibleTo Include="ZL.ProtocolGateway.Cli" />
  </ItemGroup>

  <ItemGroup>

    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"  />

    <PackageReference Include="System.IO.Ports"  />
    <PackageReference Include="System.Text.Json"  />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces"  />
    <PackageReference Include="BACnet"  />
    <PackageReference Include="MQTTnet"  />
    <PackageReference Include="Microsoft.Data.SqlClient"  />
    <PackageReference Include="OPCFoundation.NetStandard.Opc.Ua"  />
    <PackageReference Include="Dapper"  />
    <PackageReference Include="Microsoft.Data.Sqlite"  />
    <PackageReference Include="MySqlConnector"  />
    <PackageReference Include="Npgsql"  />
    <PackageReference Include="System.Threading.RateLimiting"  />
  </ItemGroup>


</Project>