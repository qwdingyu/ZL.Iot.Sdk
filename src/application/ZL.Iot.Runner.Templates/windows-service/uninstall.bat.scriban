@echo off
echo ============================================
echo {{ project_name }} Windows 服务卸载脚本
echo ============================================
echo.

sc.exe stop "{{ project_name }}" >nul 2>&1
sc.exe delete "{{ project_name }}"

if %ERRORLEVEL% EQU 0 (
    echo [成功] 服务 "{{ project_name }}" 已卸载
) else (
    echo [失败] 服务卸载失败，请以管理员身份运行此脚本
)

echo.
pause
