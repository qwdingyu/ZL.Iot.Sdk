    /// <param name="value">当前值</param>
    /// <param name="tag">标签元数据</param>
    protected override void OnTriggerDataChange(string id, object value, TagItem tag)
    {
        // TODO: 在此处编写您的自定义业务逻辑
        // 例如：当 UPLOAD_REQ=1 时，采集所有质量标签并写入数据库
        // if (id == "PRESS-A_UPLOAD_REQ" && Convert.ToInt32(value) == 1)
        // {
        //     var torque = GetCachedValue("PRESS-A_TORQUE");
        //     var angle = GetCachedValue("PRESS-A_ANGLE");
        //     // ...写入数据库或调用外部API
        // }

        // 如果不需要自定义逻辑，可调用默认处理（执行 iot_exe 规则）
        // base.OnTriggerDataChange(id, value, tag);

        System.Console.WriteLine($"[{DeviceCode}] 标签变化: {id} = {value}");
    }
}

