<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <AssemblyName>ZL.Iot.Runner.Generator</AssemblyName>
        <RootNamespace>ZL.Iot.Runner.Generator</RootNamespace>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackageId>ZL.Iot.Runner.Generator</PackageId>
    </PropertyGroup>

    <!-- 依赖 Runner 核心库（用于读取 RunnerConfig 模型） -->
    <ItemGroup>
        <PackageReference Include="ZL.Iot.Runner.Lib" />
    </ItemGroup>

    <!-- Scriban 模板引擎（版本由 Directory.Packages.props 管理） -->
    <ItemGroup>
        <PackageReference Include="Scriban" />
    </ItemGroup>

    <!-- 允许测试项目访问 internal 成员 -->
    <ItemGroup>
        <InternalsVisibleTo Include="ZL.Iot.Runner.Generator.Tests" />
    </ItemGroup>

    <!-- 模板项目作为 EmbeddedResource 编译进 Templates 程序集 -->
    <!-- PrivateAssets=all 阻止 NuGet 将 Templates 声明为传递依赖（Templates IsPackable=false） -->
    <ItemGroup>
        <ProjectReference Include="..\ZL.Iot.Runner.Templates\ZL.Iot.Runner.Templates.csproj"
                          PrivateAssets="all" />
    </ItemGroup>

</Project>
