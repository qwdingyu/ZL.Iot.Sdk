{
  "MainDB": "MainDB",
  "DBS": [
    {
      "ConnId": "MainDB",
      "DBType": {{ DatabaseType }},
      "Enabled": true,
      "HitRate": 40,
      "Connection": "{{ DatabaseConnection }}"
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
