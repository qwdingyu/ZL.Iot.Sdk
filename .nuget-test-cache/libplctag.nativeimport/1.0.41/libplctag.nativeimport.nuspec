<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>libplctag.NativeImport</id>
    <version>1.0.41</version>
    <authors>libplctag</authors>
    <license type="expression">MPL-2.0</license>
    <licenseUrl>https://licenses.nuget.org/MPL-2.0</licenseUrl>
    <icon>packageIcon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/libplctag/libplctag.NET</projectUrl>
    <description>libplctag.NativeImport provides low-level (raw) access to the native libplctag library. This package does not provide an API which is friendly to app developers. Rather, it provides an API which handles platform and configuration issues, upon which a friendlier API can be built.</description>
    <tags>plc modbus netstandard rockwell allen-bradley libplctag</tags>
