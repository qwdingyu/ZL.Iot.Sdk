<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>OmronFinsNetStandard</id>
    <version>2.0.0</version>
    <authors>volkovskey</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <description>An asynchronous Omron FINS communication library for .NET Standard with connection pooling and thread safety.</description>
    <releaseNotes>- Implemented Connection Pooling: Reuses physical TCP connections for better performance.
            - Added Thread Safety: Safe concurrent access from multiple threads.
            - Improved Error Handling: Better distinction between TCP transport errors and FINS protocol errors.
            - Refactored internal architecture while maintaining API compatibility.</releaseNotes>
    <repository type="git" url="https://github.com/volgor-soft/OmronFinsNetStandard" commit="bddf7f02d22e7b99541c06da509d9032c2ae681b" />
    <dependencies>
      <group targetFramework=".NETStandard2.1">
        <dependency id="NLog" version="5.3.4" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <contentFiles>
      <files include="any/netstandard2.1/Icons/icon.ico" buildAction="Content" />
    </contentFiles>
  </metadata>
</package>